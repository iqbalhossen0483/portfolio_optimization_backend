# Application
APP_NAME="MADRL Portfolio System"
DEBUG=false
LOG_LEVEL=INFO

# Database
POSTGRES_DSN=postgresql+asyncpg://madrl:madrl@localhost:5432/madrl_portfolio

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Market Data APIs
BLOOMBERG_API_KEY=
LESG_API_KEY=
ALPHA_VANTAGE_API_KEY=

# ADK (Google Agent Development Kit)
ADK_MODEL=gemini-2.0-flash
GOOGLE_API_KEY=

# Model Storage
MODEL_STORE_PATH=./model_store

# MASAC Hyperparameters (can override defaults from config.py)
MASAC_GAMMA=0.99
MASAC_TAU=0.005
MASAC_LR_ACTOR=0.0003
MASAC_LR_CRITIC=0.0003
MASAC_BATCH_SIZE=256
MASAC_BUFFER_CAPACITY=1000000
MASAC_WARMUP_STEPS=10000
MASAC_MAX_STEPS=500000
MASAC_HIDDEN_SIZE=256
